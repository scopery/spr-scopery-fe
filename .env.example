# ─────────────────────────────────────────────────────────────────────────────
# Data mode
# "mock" — run on local mock data, no backend required.
# ""     — live mode, requires NEXT_PUBLIC_API_URL to point to a running backend.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DATA_MODE=mock

# Backend API base URL (no trailing slash)
# Only required when NEXT_PUBLIC_DATA_MODE is not "mock".
# Sync: BE .env AUTH_REDIRECT_URL=http://localhost:<FE_PORT>/auth/callback
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (optional — only needed if Supabase features are enabled)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
