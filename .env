# Data mode
# Set to "mock" to run entirely on local mock data (no backend needed).
# Leave blank or omit to use the live backend API.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DATA_MODE=mock

# Backend API base URL (no trailing slash). FE runs on 3001, calls BE on 3000.
# Sync: BE .env AUTH_REDIRECT_URL=http://localhost:3001/auth/callback
NEXT_PUBLIC_API_URL=http://localhost:3001
