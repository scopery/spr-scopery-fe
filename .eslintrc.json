{
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended",
    "plugin:storybook/recommended",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/explicit-module-boundary-types": "off"
  },
  "overrides": [
    {
      "files": ["app/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/services/*"],
                "message": "Routes must use @/modules/{slice} instead of @/services."
              },
              {
                "group": [
                  "@/modules/*/api/*",
                  "@/modules/*/hooks/*",
                  "@/modules/*/model/*",
                  "@/modules/*/ui/*",
                  "@/modules/*/context/*"
                ],
                "message": "Import from @/modules/{slice} public index only."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["shared/ui/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/services/*", "@/modules/*"],
                "message": "Design system must not import business modules or services."
              },
              {
                "group": ["@/types/*"],
                "message": "Design system must not import business types."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["modules/**/ui/**/*.{ts,tsx}"],
      "excludedFiles": ["modules/**/ui/**/*.test.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@/shared/lib/apiClient",
                "message": "UI must not call apiClient directly — use a hook in ../hooks/."
              }
            ],
            "patterns": [
              {
                "group": [
                  "**/api/*.api",
                  "**/api/*.api.ts",
                  "@/modules/**/api/*.api",
                  "@/modules/**/api/*.api.ts",
                  "../api/*.api",
                  "../api/*.api.ts"
                ],
                "message": "UI must not import API modules directly — use hooks."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["modules/**/*.{ts,tsx}"],
      "excludedFiles": ["modules/**/api/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/services/*"],
                "message": "Use modules/{slice}/api instead of @/services."
              },
              {
                "group": [
                  "@/modules/*/*/api/*",
                  "@/modules/*/*/hooks/*",
                  "@/modules/*/*/model/*",
                  "@/modules/*/*/ui/*",
                  "@/modules/*/*/lib/*"
                ],
                "message": "Import from @/modules/{context}/{sub-module} index, or use relative imports within the same sub-module."
              }
            ]
          }
        ]
      }
    }
  ]
}
